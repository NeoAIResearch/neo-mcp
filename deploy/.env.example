# Neo MCP — environment config for HTTP server mode
# Copy this to .env and edit as needed.
# Do NOT commit .env to version control.

NEO_TRANSPORT=http
NEO_HTTP_HOST=0.0.0.0
NEO_HTTP_PORT=8000
NEO_API_URL=https://master.heyneo.so

# Optional: set fallback keys for single-user / private deployments.
# In multi-user mode, leave these blank — each user supplies keys via
# request headers (x-access-key and Authorization: Bearer).
# NEO_API_KEY=ak-v1-...
# NEO_SECRET_KEY=sk-v1-...

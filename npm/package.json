{
  "name": "neo-mcp-daemon",
  "version": "1.0.1",
  "description": "Neo local execution daemon — runs AI/ML tasks locally, no Python required",
  "main": "dist/index.js",
  "bin": {
    "neo-mcp-daemon": "bin/neo-mcp-daemon"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"

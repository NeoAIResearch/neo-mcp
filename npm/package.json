    "mcp",
    "daemon",
    "ai",
    "ml",
    "local-execution"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
